# ------------------------------
# Required: Aliyun DNS API creds
# ------------------------------
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCESS_KEY_ID=replace-with-access-key-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-access-key-secret

# ------------------------------
# Required: certificate target
# ------------------------------
CERT_DOMAIN=api.jarvis.xense-ai.com
CERTBOT_EMAIL=ops@xense-ai.com

# ------------------------------
# Required: arch certificate output directories
# ------------------------------
# Certificate files (.crt/.pem), e.g. /etc/ssl/certs
ARCH_CERTS_DIR=/etc/ssl/certs
# Private key files (.key), e.g. /etc/ssl/private
ARCH_PRIVATE_DIR=/etc/ssl/private

# ------------------------------
# Optional defaults
# ------------------------------
DOCKER_IMAGE=justjavac/certbot-dns-aliyun:latest
LETSENCRYPT_STATE_DIR=/var/lib/jarvis-letsencrypt
ARCH_CERT_CRT_NAME=api.jarvis.xense-ai.com.crt
ARCH_CERT_PEM_NAME=api.jarvis.xense-ai.com.pem
ARCH_KEY_NAME=api.jarvis.xense-ai.com.key

# Set true for dry-run validation (no real cert file deployment)
CERTBOT_DRY_RUN=false

# Run after cert/key copied to ARCH_CERTS_DIR and ARCH_PRIVATE_DIR.
# Example:
# POST_DEPLOY_CMD=docker restart jarvis-server
POST_DEPLOY_CMD=

# Monthly schedule (minute hour day month weekday)
CRON_SCHEDULE=0 3 1 * *
CRON_LOG_PATH=/var/log/jarvis-certbot.log
LOCK_FILE=/tmp/jarvis-certbot-aliyun.lock
