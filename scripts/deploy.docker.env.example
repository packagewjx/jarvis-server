# Docker image/container
DOCKER_IMAGE=jarvis-server:docker
DOCKER_CONTAINER=jarvis-server
POSTGRES_CONTAINER=jarvis-postgres
DOCKER_NETWORK=jarvis-net
POSTGRES_VOLUME=jarvis-postgres-data
DOCKERFILE_PATH=
DOCKER_CONTEXT=

# Host <-> container port mapping
HOST_HTTPS_PORT=8443
NGINX_LISTEN_PORT=443
NGINX_SERVER_NAME=_

# Host TLS files (required for `start`)
TLS_CERT_PATH=/absolute/path/server.crt
TLS_KEY_PATH=/absolute/path/server.key

# Container TLS mount path (usually no need to change)
CONTAINER_TLS_CERT_PATH=/etc/nginx/tls/server.crt
CONTAINER_TLS_KEY_PATH=/etc/nginx/tls/server.key

# Jarvis server runtime
JARVIS_SERVER_HOST=127.0.0.1
JARVIS_SERVER_PORT=18080
JARVIS_CHAT_RETENTION_DAYS=7
JARVIS_JWT_SECRET=dev-jwt-secret-change-me
JARVIS_JWT_ISSUER=jarvis-server
JARVIS_JWT_ACCESS_TTL_SEC=7200
JARVIS_JWT_REFRESH_TTL_SEC=2592000

# PostgreSQL config
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis
POSTGRES_HOST_PORT=5432
JARVIS_DB_JDBC_URL=jdbc:postgresql://jarvis-postgres:5432/jarvis
JARVIS_DB_USER=jarvis
JARVIS_DB_PASSWORD=jarvis
JARVIS_DB_MAX_POOL_SIZE=10

# Channel gateway config (required by server process, can be dummy if you only use /health or /api/voice/*)
JARVIS_CHANNEL_BASE_URL=https://127.0.0.1:9443
JARVIS_CHANNEL_AUTH_TOKEN=dummy-channel-token
JARVIS_CHANNEL_CONNECT_TIMEOUT_MS=10000
JARVIS_CHANNEL_READ_TIMEOUT_MS=60000
JARVIS_CHANNEL_HOSTNAME_VERIFICATION=false

# XFYun IAT sign-url API config
JARVIS_XFYUN_IAT_APP_ID=
JARVIS_XFYUN_IAT_API_KEY=
JARVIS_XFYUN_IAT_API_SECRET=
JARVIS_XFYUN_IAT_HOST=iat.cn-huabei-1.xf-yun.com
JARVIS_XFYUN_IAT_PATH=/v1
JARVIS_XFYUN_IAT_TTL_SEC=120
JARVIS_XFYUN_IAT_RATE_LIMIT_PER_MIN=30
JARVIS_XFYUN_IAT_DEFAULT_SAMPLE_RATE=16000
JARVIS_XFYUN_IAT_DEFAULT_DOMAIN=slm
JARVIS_XFYUN_IAT_DEFAULT_LANGUAGE=zh_cn
JARVIS_XFYUN_IAT_DEFAULT_ACCENT=mulacc
JARVIS_XFYUN_IAT_AUDIO_ENCODING=lame
