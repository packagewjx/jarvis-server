# Docker image/container
DOCKER_IMAGE=jarvis-server:docker
DOCKER_CONTAINER=jarvis-server
POSTGRES_CONTAINER=jarvis-postgres
DOCKER_NETWORK=jarvis-net
POSTGRES_VOLUME=jarvis-postgres-data
DOCKERFILE_PATH=
DOCKER_CONTEXT=

# Host <-> container port mapping
HOST_HTTPS_PORT=8443
NGINX_LISTEN_PORT=443
NGINX_SERVER_NAME=_

# Host TLS files (required for `start`)
TLS_CERT_PATH=/absolute/path/server.crt
TLS_KEY_PATH=/absolute/path/server.key

# Container TLS mount path (usually no need to change)
CONTAINER_TLS_CERT_PATH=/etc/nginx/tls/server.crt
CONTAINER_TLS_KEY_PATH=/etc/nginx/tls/server.key

# Jarvis server runtime
JARVIS_SERVER_HOST=127.0.0.1
JARVIS_SERVER_PORT=18080
JARVIS_CHAT_RETENTION_DAYS=7
JARVIS_JWT_SECRET=dev-jwt-secret-change-me
JARVIS_JWT_ISSUER=jarvis-server
JARVIS_JWT_ACCESS_TTL_SEC=7200
JARVIS_JWT_REFRESH_TTL_SEC=2592000

# PostgreSQL config
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis
POSTGRES_HOST_PORT=5432
JARVIS_DB_JDBC_URL=jdbc:postgresql://jarvis-postgres:5432/jarvis
JARVIS_DB_USER=jarvis
JARVIS_DB_PASSWORD=jarvis
JARVIS_DB_MAX_POOL_SIZE=10

# Channel gateway config (required by server process, can be dummy if you only use /health or /api/voice/*)
JARVIS_CHANNEL_BASE_URL=https://127.0.0.1:9443
JARVIS_CHANNEL_AUTH_TOKEN=dummy-channel-token
JARVIS_CHANNEL_CONNECT_TIMEOUT_MS=10000
JARVIS_CHANNEL_READ_TIMEOUT_MS=60000
JARVIS_CHANNEL_HOSTNAME_VERIFICATION=false

# OpenClaw bridge container (recommended: keep enabled to get real OpenClaw replies)
OPENCLAW_BRIDGE_ENABLED=true
OPENCLAW_BRIDGE_CONTAINER=jarvis-openclaw-bridge
OPENCLAW_BRIDGE_IMAGE=node:24-bookworm
# Defaults to JARVIS_CHANNEL_AUTH_TOKEN when empty
# OPENCLAW_BRIDGE_AUTH_TOKEN=dummy-channel-token
# Bridge host/port. If port is empty, script derives from JARVIS_CHANNEL_BASE_URL.
OPENCLAW_BRIDGE_CHANNEL_HOST=0.0.0.0
OPENCLAW_BRIDGE_CHANNEL_PORT=
# Optional; if empty script derives network alias from JARVIS_CHANNEL_BASE_URL hostname.
OPENCLAW_BRIDGE_NETWORK_ALIAS=
OPENCLAW_BRIDGE_COMMAND_ALLOWLIST=help,status,new,reset,think,verbose
OPENCLAW_BRIDGE_COMMAND_RATE_LIMIT_PER_MIN=30
OPENCLAW_BRIDGE_COMMAND_AUTO_DETECT_SLASH=true
OPENCLAW_BRIDGE_AGENT_LOCAL=true
OPENCLAW_BRIDGE_AGENT_TIMEOUT_MS=180000
OPENCLAW_BRIDGE_AGENT_WORKDIR=/workspace/openclaw-channel

# The script generates a minimal OpenClaw config for bridge use only.
# Source config should point to a working local OpenClaw config that includes models.providers.
OPENCLAW_BRIDGE_OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# Generated file path. Relative paths are resolved from repo root.
OPENCLAW_BRIDGE_GENERATED_CONFIG_PATH=.run/openclaw-bridge.json
# Container path for the generated config (usually no need to change)
OPENCLAW_BRIDGE_CONTAINER_CONFIG_PATH=/workspace/.run/openclaw-bridge.json
# Optional fixed provider/model selection. Empty means "first provider + first model in source config".
OPENCLAW_BRIDGE_PROVIDER_ID=
OPENCLAW_BRIDGE_MODEL_ID=
# Bridge TLS defaults to TLS_CERT_PATH / TLS_KEY_PATH when empty
# OPENCLAW_BRIDGE_TLS_CERT_PATH=/absolute/path/server.crt
# OPENCLAW_BRIDGE_TLS_KEY_PATH=/absolute/path/server.key
OPENCLAW_BRIDGE_CONTAINER_TLS_CERT_PATH=/workspace/.run/bridge.crt
OPENCLAW_BRIDGE_CONTAINER_TLS_KEY_PATH=/workspace/.run/bridge.key

# XFYun IAT sign-url API config
JARVIS_XFYUN_IAT_APP_ID=
JARVIS_XFYUN_IAT_API_KEY=
JARVIS_XFYUN_IAT_API_SECRET=
JARVIS_XFYUN_IAT_HOST=iat.cn-huabei-1.xf-yun.com
JARVIS_XFYUN_IAT_PATH=/v1
JARVIS_XFYUN_IAT_TTL_SEC=120
JARVIS_XFYUN_IAT_RATE_LIMIT_PER_MIN=30
JARVIS_XFYUN_IAT_DEFAULT_SAMPLE_RATE=16000
JARVIS_XFYUN_IAT_DEFAULT_DOMAIN=slm
JARVIS_XFYUN_IAT_DEFAULT_LANGUAGE=zh_cn
JARVIS_XFYUN_IAT_DEFAULT_ACCENT=mulacc
JARVIS_XFYUN_IAT_AUDIO_ENCODING=lame

# XFYun TTS sign-url API config
# If left empty, APP_ID/API_KEY/API_SECRET fallback to IAT credentials in server config.
JARVIS_XFYUN_TTS_APP_ID=
JARVIS_XFYUN_TTS_API_KEY=
JARVIS_XFYUN_TTS_API_SECRET=
JARVIS_XFYUN_TTS_HOST=tts-api.xfyun.cn
JARVIS_XFYUN_TTS_PATH=/v2/tts
JARVIS_XFYUN_TTS_TTL_SEC=120
JARVIS_XFYUN_TTS_RATE_LIMIT_PER_MIN=30
JARVIS_XFYUN_TTS_DEFAULT_VCN=xiaoyan
JARVIS_XFYUN_TTS_DEFAULT_SPEED=50
JARVIS_XFYUN_TTS_DEFAULT_PITCH=50
JARVIS_XFYUN_TTS_DEFAULT_VOLUME=50
JARVIS_XFYUN_TTS_DEFAULT_SAMPLE_RATE=16000
JARVIS_XFYUN_TTS_DEFAULT_AUDIO_ENCODING=lame
JARVIS_XFYUN_TTS_DEFAULT_TEXT_ENCODING=utf8

# XFYun Super Smart-TTS sign-url API config
# If left empty, APP_ID/API_KEY/API_SECRET fallback to IAT credentials in server config.
JARVIS_XFYUN_SUPER_TTS_APP_ID=
JARVIS_XFYUN_SUPER_TTS_API_KEY=
JARVIS_XFYUN_SUPER_TTS_API_SECRET=
JARVIS_XFYUN_SUPER_TTS_HOST=cbm01.cn-huabei-1.xf-yun.com
JARVIS_XFYUN_SUPER_TTS_PATH=/v1/private/mcd9m97e6
JARVIS_XFYUN_SUPER_TTS_TTL_SEC=120
JARVIS_XFYUN_SUPER_TTS_RATE_LIMIT_PER_MIN=30
JARVIS_XFYUN_SUPER_TTS_DEFAULT_VCN=x4_lingxiaoxuan_oral
JARVIS_XFYUN_SUPER_TTS_DEFAULT_SPEED=50
JARVIS_XFYUN_SUPER_TTS_DEFAULT_PITCH=50
JARVIS_XFYUN_SUPER_TTS_DEFAULT_VOLUME=50
JARVIS_XFYUN_SUPER_TTS_DEFAULT_SAMPLE_RATE=24000
JARVIS_XFYUN_SUPER_TTS_DEFAULT_AUDIO_ENCODING=raw
JARVIS_XFYUN_SUPER_TTS_DEFAULT_REG=0
JARVIS_XFYUN_SUPER_TTS_DEFAULT_RDN=0
JARVIS_XFYUN_SUPER_TTS_DEFAULT_RHY=0
JARVIS_XFYUN_SUPER_TTS_DEFAULT_SCN=0

# XFYun ISV (voiceprint) sign-url API config
# If left empty, APP_ID/API_KEY/API_SECRET fallback to IAT credentials in server config.
JARVIS_XFYUN_ISV_APP_ID=
JARVIS_XFYUN_ISV_API_KEY=
JARVIS_XFYUN_ISV_API_SECRET=
JARVIS_XFYUN_ISV_HOST=api.xf-yun.com
JARVIS_XFYUN_ISV_PATH=/v1/private/s1aa729d0
JARVIS_XFYUN_ISV_TTL_SEC=120
JARVIS_XFYUN_ISV_RATE_LIMIT_PER_MIN=30
