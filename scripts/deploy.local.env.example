# ------------------------------
# Required secrets
# ------------------------------

# Token written to OpenClaw config:
# channels.jarvis-openclaw.token
OPENCLAW_CHANNEL_TOKEN=replace-with-openclaw-channel-token

# Shared bearer token between Kotlin server and openclaw-channel HTTPS bridge
JARVIS_CHANNEL_AUTH_TOKEN=replace-with-bridge-auth-token

# Optional override if you want bridge auth token to differ from JARVIS_CHANNEL_AUTH_TOKEN
# OPENCLAW_CHANNEL_AUTH_TOKEN=replace-with-bridge-auth-token

# ------------------------------
# Optional Jarvis server config
# ------------------------------
# Requires local JDK 17 (`java` and `javac` must both be version 17)
JARVIS_SERVER_HOST=127.0.0.1
JARVIS_SERVER_PORT=8080
JARVIS_CHAT_RETENTION_DAYS=7
JARVIS_JWT_SECRET=dev-jwt-secret-change-me
JARVIS_JWT_ISSUER=jarvis-server
JARVIS_JWT_ACCESS_TTL_SEC=7200
JARVIS_JWT_REFRESH_TTL_SEC=2592000
# PostgreSQL connection (required for message persistence and sync)
JARVIS_DB_JDBC_URL=jdbc:postgresql://127.0.0.1:5432/jarvis
JARVIS_DB_USER=jarvis
JARVIS_DB_PASSWORD=jarvis
JARVIS_DB_MAX_POOL_SIZE=10
# XFYun IAT sign-url API credentials (required if you need /api/voice/iat-sign-url)
# JARVIS_XFYUN_IAT_APP_ID=64ff2388
# JARVIS_XFYUN_IAT_API_KEY=replace-with-xfyun-api-key
# JARVIS_XFYUN_IAT_API_SECRET=replace-with-xfyun-api-secret
# Optional defaults:
# JARVIS_XFYUN_IAT_HOST=iat.cn-huabei-1.xf-yun.com
# JARVIS_XFYUN_IAT_PATH=/v1
# JARVIS_XFYUN_IAT_TTL_SEC=120
# JARVIS_XFYUN_IAT_RATE_LIMIT_PER_MIN=30
# JARVIS_XFYUN_IAT_DEFAULT_SAMPLE_RATE=16000
# JARVIS_XFYUN_IAT_DEFAULT_DOMAIN=slm
# JARVIS_XFYUN_IAT_DEFAULT_LANGUAGE=zh_cn
# JARVIS_XFYUN_IAT_DEFAULT_ACCENT=mulacc
# JARVIS_XFYUN_IAT_AUDIO_ENCODING=lame
# Jarvis -> openclaw-channel access URL (must be https://...)
# If omitted, script derives it from OPENCLAW_CHANNEL_HOST/PORT:
# https://${OPENCLAW_CHANNEL_HOST}:${OPENCLAW_CHANNEL_PORT}
JARVIS_CHANNEL_BASE_URL=https://127.0.0.1:9443
JARVIS_CHANNEL_CONNECT_TIMEOUT_MS=10000
JARVIS_CHANNEL_READ_TIMEOUT_MS=60000
JARVIS_CHANNEL_HOSTNAME_VERIFICATION=true

# ------------------------------
# Optional openclaw-channel bridge config
# ------------------------------
# openclaw-channel bind/listen address
# Not conflicting with JARVIS_CHANNEL_BASE_URL:
# these two are listener settings, BASE_URL is client-side access URL.
OPENCLAW_CHANNEL_HOST=127.0.0.1
OPENCLAW_CHANNEL_PORT=9443
# OpenClaw agent bridge runtime (real model reply path)
# OPENCLAW_AGENT_WORKDIR=/absolute/path/that_contains_openclaw_cli
# OPENCLAW_AGENT_ID=main
# OPENCLAW_AGENT_LOCAL=true
# OPENCLAW_AGENT_TIMEOUT_MS=180000
# OPENCLAW_AGENT_THINKING=low

# Optional comma-separated allowlist for dmSecurity=allowlist
# Example: OPENCLAW_CHANNEL_ALLOW_FROM=user_001,user_002
OPENCLAW_CHANNEL_ALLOW_FROM=
OPENCLAW_CHANNEL_DM_SECURITY=allowlist

# ------------------------------
# Optional paths
# ------------------------------
# OPENCLAW_CHANNEL_DIR=/absolute/path/to/openclaw-channel
# JARVIS_REPO_ROOT=/absolute/path/to/jarvis-server
# GRADLE_CMD=gradle
# USE_SYSTEM_OPENCLAW=true
# OPENCLAW_CONFIG_PATH=${HOME}/.openclaw/openclaw.json
# OPENCLAW_STATE_DIR=

# OPENCLAW_CHANNEL_TLS_KEY_PATH=/absolute/path/key.pem
# OPENCLAW_CHANNEL_TLS_CERT_PATH=/absolute/path/cert.pem
# JARVIS_CHANNEL_CA_CERT_PATH=/absolute/path/cert.pem
# TLS_CERT_CN=localhost
# TLS_CERT_SAN=DNS:localhost,IP:127.0.0.1

# RUN_DIR=/absolute/path/.run
# LOG_DIR=/absolute/path/.logs
# CERT_DIR=/absolute/path/.certs
